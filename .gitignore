# Environments
venv/
.env
.env.local
.vscode/
node_modules/
.next/
out/
build/

# Python Cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Local Data (PERSONAL & SECURE)
# We ignore the entire local data directory to preserve user privacy
backend/data/local/*
!backend/data/local/.gitkeep

# Audio & Media (Keep local/temp audio ignored)
backend/data/local/voice/*
*.mp3
*.wav

# Allow documentation screenshots
!screenshots/*.png
!screenshots/*.jpg
!screenshots/*.jpeg
!screenshots/*.webp

# OS Files
.DS_Store
Thumbs.db
